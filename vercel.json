{
  "framework": "nextjs",
  "buildCommand": "bun run build",
  "outputDirectory": ".next/standalone",
  "installCommand": "bun install",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
